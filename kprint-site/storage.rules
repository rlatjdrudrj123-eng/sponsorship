rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /categories/{categoryId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['admin@kprint.kr'];
    }
    match /packages/{packageId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['admin@kprint.kr'];
    }
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['admin@kprint.kr'];
    }
    // 랜딩 빌더 캔버스 업로드 (canvas-upload / canvas-paste / canvas-page-bg / canvas-multi 등)
    match /landing/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['admin@kprint.kr'];
    }
  }
}
